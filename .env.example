APP_NAME="Invoice Validation Copilot"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Public HTTPS URL for the app. In production set this to your domain (e.g. https://invoices.example.com).
# The mobile-upload QR code and all Vite asset URLs derive from this value — it must be correct
# for the phone camera and browser to resolve assets from the right host.
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_AU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# No database is used. The invoice pipeline runs entirely in-memory per request,
# so sessions, cache, and queue use non-DB drivers and no migrations are run.
DB_CONNECTION=null

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Anthropic Claude API key — required for vision extraction and the text
# explanation step. Leave blank in CI/tests; the ClaudeClient seam is always
# mocked in tests so they never hit the network.
ANTHROPIC_API_KEY=

# Claude model used for both LLM calls (vision extraction + explanation).
# Defaults to claude-opus-4-8; override here to pin a different model version.
ANTHROPIC_MODEL=claude-opus-4-8

VITE_APP_NAME="${APP_NAME}"
